{
  "name": "@vskstudio/takt-mcp",
  "version": "0.2.1",
  "description": "Model Context Protocol server for Takt privacy-friendly analytics — query your sites' stats from any MCP-aware AI agent",
  "license": "MIT",
  "author": "VSK Studio",
  "type": "module",
  "bin": {
    "takt-mcp": "./dist/index.js"
  },
  "types": "./dist/index.d.ts",
  "keywords": [
    "analytics",
    "privacy",
    "mcp",
    "model-context-protocol",
    "takt",
    "ai"
  ],
  "homepage": "https://github.com/vskstudio/takt-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vskstudio/takt-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/vskstudio/takt-mcp/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "prepublishOnly": "pnpm build",
    "release": "changeset publish"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.1.0"
  },
  "packageManager": "pnpm@9.0.0"
}
